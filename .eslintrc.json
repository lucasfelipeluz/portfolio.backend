{
  "root": true,
  "env": {
    "es2021": true,
    "node": true
  },
  "extends": "airbnb",
  "overrides": [],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": ["@typescript-eslint"],
  "rules": {
    "operator-linebreak": "off",
    "object-curly-newline": "off",
    "linebreak-style": 0,
    "no-console": "off",
    "max-len": ["warn", { "code": 100 }]
  }
}
